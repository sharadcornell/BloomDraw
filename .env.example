# BloomDraw — example environment file
# Copy to `.env` and fill in. `.env` is git-ignored; ONLY `.env.example` is committed.
#
# RULES
#  - EXPO_PUBLIC_* vars are bundled into the mobile app and are PUBLIC. Never put secrets here.
#  - Secret keys (AI provider keys, Supabase service-role) are SERVER-SIDE ONLY.
#    Set them as Supabase Edge Function secrets: `supabase secrets set NAME=value`.
#    They must NEVER appear in the app bundle, in any EXPO_PUBLIC_* var, or in source.
#  - With no keys set (or AI_MOCK_MODE=true), the app runs fully in MOCK mode (Demo badge).

# ─────────────────────────────────────────────────────────────
# App (CLIENT) — safe to ship; bundled into the app
# ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# development | staging | production
EXPO_PUBLIC_APP_ENV=development

# Optional DEV-ONLY override: force the mock AI path even when Supabase/keys are configured
# (useful for offline demos). Leave false/blank in staging/production.
EXPO_PUBLIC_FORCE_MOCK=false

# ─────────────────────────────────────────────────────────────
# Supabase (SERVER / tooling) — do NOT expose to the app
# ─────────────────────────────────────────────────────────────
# Secret. Edge Functions only (set via `supabase secrets set`). Never EXPO_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
# Project ref for CLI/CI (not secret).
SUPABASE_PROJECT_REF=

# ─────────────────────────────────────────────────────────────
# AI providers (SERVER / Edge Functions) — SECRET, server-side only
# ─────────────────────────────────────────────────────────────
# Secret. Used only inside Supabase Edge Functions.
OPENAI_API_KEY=
# Secret. Alternate provider.
REPLICATE_API_TOKEN=

# Which provider to use when not in mock mode: openai | replicate | mock
AI_PROVIDER=openai

# Master switch for the mock fallback.
#  - true  (default/dev): always use the Mock provider; no external AI calls; safe for demos.
#  - false (real):        use AI_PROVIDER; if its key is missing, the server falls back to Mock and logs a warning.
AI_MOCK_MODE=true

# ─────────────────────────────────────────────────────────────
# AI model IDs (SERVER / Edge Functions) — CONFIG, NOT CODE
# Verify the exact current IDs at implementation time; do not hardcode in source.
# Leave blank to use the documented defaults in _shared/ai-provider/config.ts.
# ─────────────────────────────────────────────────────────────
OPENAI_MODERATION_MODEL=
OPENAI_REWRITE_MODEL=
OPENAI_IMAGE_MODEL=
REPLICATE_IMAGE_MODEL=

# ─────────────────────────────────────────────────────────────
# AI rate limiting & spend caps (SERVER / Edge Functions) — real mode only
# Mock mode is ALWAYS unlimited.
#  - Per-device/session limit (anti-abuse): over-limit → "take a tiny break" message.
#  - Global daily cap (cost protection): cap reached → "Our art helper is resting for now."
#  - Per-device is checked before global. No cost/spend detail is ever shown to the child.
#  - Spend cap is provider-dependent: the request-count cap is enforced first;
#    AI_GLOBAL_DAILY_SPEND_CAP_USD is wired to provider budget/usage before the real-key pilot.
# ─────────────────────────────────────────────────────────────
AI_RATE_LIMIT_ENABLED=true
AI_RATE_LIMIT_PER_DAY=50
AI_GLOBAL_DAILY_LIMIT=500
AI_GLOBAL_DAILY_SPEND_CAP_USD=
AI_LIMIT_WINDOW_HOURS=24

# ─────────────────────────────────────────────────────────────
# AI latency (SERVER / Edge Functions) — optional
# Upstream provider-call timeout (ms). Each function caps its provider call below
# the Edge platform wall-clock limit and returns the child-safe "nap" retry on
# timeout (docs/05 §12). Default 25000. Mock mode returns immediately.
# ─────────────────────────────────────────────────────────────
AI_PROVIDER_TIMEOUT_MS=25000

# ─────────────────────────────────────────────────────────────
# Data retention (SERVER / DB) — anonymous images + metadata
# Days to keep anonymous uploaded/AI images before the scheduled purge.
# Default 30. Set 0 (or unset) to disable purging in local dev.
# ─────────────────────────────────────────────────────────────
DATA_RETENTION_DAYS=30
